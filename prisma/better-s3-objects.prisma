// better-s3 — Object & Upload Tracking (Org)
// Requires: better-auth User + Organization + Team (optional)
// do not edit this file

enum StorageVisibility {
  private
  team
  organization
  public

  @@map("storage_visibility")
  @@schema("storage")
}

enum StorageObjectStatus {
  active
  archived
  deleted

  @@map("storage_object_status")
  @@schema("storage")
}

enum UploadStatus {
  pending // in-progress
  complete // verified via HeadObject
  aborted
  expired // cleaned up by cron or S3 lifecycle rule

  @@map("upload_status")
  @@schema("storage")
}

model StorageObject {
  id String @id @default(cuid())

  key    String @unique
  bucket String

  contentType String? @map("content_type")
  size        Int? // bytes, from HeadObject
  eTag        String? @map("etag")
  filename    String? // original client filename

  name        String? // user-facing label
  description String?

  visibility StorageVisibility   @default(private)
  status     StorageObjectStatus @default(active)

  publicUrl String? @map("public_url") // CDN / custom domain URL when visibility = public

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  teamId String? @map("team_id")
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // soft-delete

  upload        Upload?
  questionMedia Question[] @relation("QuestionMedia")
  examFiles     ExamFile[] @relation("ExamFileObject")

  @@index([userId])
  @@index([organizationId])
  @@index([teamId])
  @@index([status])
  @@index([bucket, key])
  @@map("storage_object")
  @@schema("storage")
}

// Tracks in-progress and completed uploads. Retained after completion for audit.
model Upload {
  id String @id @default(cuid())

  key      String  @unique
  bucket   String
  uploadId String? @map("upload_id") // multipart only

  contentType  String? @map("content_type")
  declaredSize Int?    @map("declared_size") // client-declared, pre-upload
  verifiedSize Int?    @map("verified_size") // confirmed by HeadObject
  eTag         String? @map("etag")

  status UploadStatus @default(pending)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  storageObjectId String?        @unique @map("storage_object_id")
  storageObject   StorageObject? @relation(fields: [storageObjectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([organizationId])
  @@index([status, createdAt]) // cron: WHERE status = 'pending' AND createdAt < X
  @@map("upload")
  @@schema("storage")
}
