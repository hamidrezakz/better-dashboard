// better-s3 — Storage Quota & Usage (Org)
// Requires: better-auth User + Organization + better-s3-objects.prisma
// do not edit this file

enum QuotaOwnerType {
  user
  organization

  @@map("quota_owner_type")
  @@schema("storage")
}

enum UsagePeriod {
  daily
  monthly

  @@map("usage_period")
  @@schema("storage")
}

// One row per organization. maxBytes / maxObjects = null means unlimited.
// usedBytes / usedObjects are live totals — use for enforcement, not StorageUsage.
model StorageQuota {
  id String @id @default(cuid())

  ownerType QuotaOwnerType @default(organization) @map("owner_type")

  userId String @map("user_id") // billing contact / org creator
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String       @unique @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  maxBytes   BigInt? @map("max_bytes")
  maxObjects Int?    @map("max_objects")

  // Op limits per billing period — check against current-period StorageUsage row.
  // Deletes are intentionally not limited to avoid storage bloat.
  maxWriteOps Int? @map("max_write_ops")
  maxReadOps  Int? @map("max_read_ops")
  maxListOps  Int? @map("max_list_ops")

  usedBytes   BigInt @default(0) @map("used_bytes")
  usedObjects Int    @default(0) @map("used_objects")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("storage_quota")
  @@schema("storage")
}

// Point-in-time snapshots for dashboard charts. Append-only, cron-generated.
// Do NOT use for enforcement — use StorageQuota.usedBytes instead.
model StorageUsage {
  id String @id @default(cuid())

  ownerType QuotaOwnerType @default(organization) @map("owner_type")
  period    UsagePeriod

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  totalBytes   BigInt @default(0) @map("total_bytes")
  totalObjects Int    @default(0) @map("total_objects")

  // writes: PutObject, CopyObject, multipart (PUT class)
  writeOps   Int    @default(0) @map("write_ops")
  writeBytes BigInt @default(0) @map("write_bytes")

  // reads: GetObject, HeadObject — HEAD counts as 1 op, 0 bytes
  readOps   Int    @default(0) @map("read_ops")
  readBytes BigInt @default(0) @map("read_bytes")

  // lists: ListObjectsV2 — charged per 1,000 requests, no byte count
  listOps Int @default(0) @map("list_ops")

  // deletes: DeleteObject / DeleteObjects
  deleteOps   Int    @default(0) @map("delete_ops")
  deleteBytes BigInt @default(0) @map("delete_bytes")

  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([organizationId, period, periodStart])
  @@index([userId])
  @@index([organizationId, period])
  @@index([periodStart])
  @@map("storage_usage")
  @@schema("storage")
}
