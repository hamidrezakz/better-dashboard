// better-s3 — Activity Log (Org)
// Requires: better-auth User + Organization + better-s3-objects.prisma
// do not edit this file

enum ActivityAction {
  upload // confirmed via HeadObject
  download // presigned URL issued
  delete

  @@map("activity_action")
  @@schema("storage")
}

// Append-only. Stores object coordinates directly so the log survives deletion.
model StorageActivityLog {
  id String @id @default(cuid())

  action ActivityAction

  key    String
  bucket String
  bytes  BigInt? // null if size was unavailable at delete time

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  teamId String? @map("team_id")

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([key])
  @@index([action, createdAt])
  @@map("storage_activity_log")
  @@schema("storage")
}
